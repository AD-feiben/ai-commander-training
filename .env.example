# =============================================================================
# Giscus 评论系统配置（可选）
# =============================================================================
# ⚠️ 重要提示：
# - 请勿将包含真实配置的 .env 文件提交到 Git！
# - 此文件仅作为示例，已在 .gitignore 中忽略 .env 文件
# - 每个部署实例应该使用自己的 Giscus 配置
#
# 配置步骤：
# 1. 确保你的 GitHub 仓库已启用 Discussions 功能
#    (Settings > General > Features > Discussions)
# 2. 访问 https://giscus.app/ 获取配置信息
# 3. 复制此文件为 .env 并填写你的配置
# 4. 重新构建项目
# =============================================================================

# GitHub 仓库（格式：用户名/仓库名）
# 示例：VITE_GISCUS_REPO=username/my-blog
VITE_GISCUS_REPO=

# 仓库 ID（从 giscus.app 获取）
# 示例：VITE_GISCUS_REPO_ID=R_kgDOGxxxx
VITE_GISCUS_REPO_ID=

# Discussion 分类名称
# 默认值：General
VITE_GISCUS_CATEGORY=General

# 分类 ID（从 giscus.app 获取）
# 示例：VITE_GISCUS_CATEGORY_ID=DIC_kwDOGxxxx
VITE_GISCUS_CATEGORY_ID=

# 映射方式：pathname | url | title | og:title | specific
# - pathname: 使用页面路径作为讨论标题
# - url: 使用完整 URL
# - title: 使用页面标题
# - og:title: 使用 Open Graph 标题
# - specific: 使用特定字符串（需要配合 term 参数）
VITE_GISCUS_MAPPING=specific

# 是否启用反应（表情）：true | false
VITE_GISCUS_REACTIONS_ENABLED=true

# 是否发送元数据：true | false
VITE_GISCUS_EMIT_METADATA=false

# 输入框位置：top | bottom
VITE_GISCUS_INPUT_POSITION=top
